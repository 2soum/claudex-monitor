{
  "name": "claudex-monitor",
  "version": "0.3.0",
  "description": "Local Claude Code monitor — reads your .jsonl sessions, streams to an iPad companion over LAN, and posts daily aggregates to the public Claudex leaderboard.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claudex": "bin/claudex.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli.ts",
    "prod": "npm run build && npm start",
    "test": "tsx --test src/pricing.test.ts src/rtkTracker.test.ts src/usageCollector.test.ts"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "chokidar": "^4.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/2soum/claudex-monitor"
  },
  "keywords": [
    "claude",
    "claude-code",
    "leaderboard",
    "monitor",
    "tokens"
  ],
  "license": "MIT"
}
