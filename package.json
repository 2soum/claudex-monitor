{
  "name": "claude-token-monitor-server",
  "version": "1.0.0",
  "description": "Local WebSocket server broadcasting Claude token usage to iPad over LAN via Bonjour",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "prod": "npm run build && npm start",
    "test": "tsx --test src/pricing.test.ts src/rtkTracker.test.ts src/usageCollector.test.ts"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "chokidar": "^4.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
